# Configuration de l'environnement

# Mode d'exécution (development, production)
NODE_ENV=development

# URI de connexion MongoDB
# En local avec Docker Compose : mongodb://mongo:27017/samsoul
# En production : mongodb://host:port/database
MONGO_URI=mongodb://mongo:27017/samsoul

# Port de l'API (optionnel, par défaut 3000)
PORT=3000

