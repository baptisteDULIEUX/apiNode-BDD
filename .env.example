# MongoDB Connection URI (utiliser MONGO_URI pour correspondre avec docker-compose.yml)
MONGO_URI=mongodb://mongo:27017/samsoul

# Server Port
PORT=3000

# Environment (development, test, production)
NODE_ENV=development

# JWT Secret pour l'authentification (IMPORTANT: générer une clé forte en production)
# Pour générer: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

